# Supabase — copy this file to .env.local and fill in real values.
# Dashboard: Project Settings > API. Use the "Publishable" key (safe for the browser).
# NEVER put the secret key here — it bypasses all security and must stay server-side only.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# Shared admin password for the /admin login gate (client-side only — demo grade).
VITE_ADMIN_PASSWORD=change-me
